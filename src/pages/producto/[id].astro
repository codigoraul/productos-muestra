---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ProductCard from '../../components/ProductCard.astro';
import CartDrawer from '../../components/CartDrawer.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
import { products, PLACEHOLDER } from '../../data/products.js';

export function getStaticPaths() {
  return products.map((p) => ({ params: { id: String(p.id) }, props: { product: p } }));
}

const { product } = Astro.props;
const { id, nombre, categoria, precio, precioAnterior, rating, reviews, imagen, galeria, badge, descripcion } = product;
const fotos = galeria ?? [imagen];
const stars = '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
const fmt = (n) => n.toLocaleString('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
const descuento = precioAnterior ? Math.round((1 - precio / precioAnterior) * 100) : 0;
const relacionados = products.filter((p) => p.categoria === categoria && p.id !== id).slice(0, 4);
---
<Layout title={`${nombre} — NovaTech`} description={descripcion}>
  <Header />

  <main class="container main">
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/">Inicio</a>
      <span class="sep">›</span>
      <a href="/productos/">Productos</a>
      <span class="sep">›</span>
      <a href={`/productos/?cat=${encodeURIComponent(categoria)}`}>{categoria}</a>
      <span class="sep">›</span>
      <span class="current">{nombre}</span>
    </nav>

    <section
      class="detail"
      data-id={id}
      data-nombre={nombre}
      data-precio={precio}
      data-img={imagen}
    >
      <!-- Galería: imagen principal + thumbnails en columna derecha -->
      <div class="gallery-wrap">
        <div class="gallery-main">
          <img id="gallery-active" src={fotos[0]} alt={nombre} title="Clic para ampliar" onerror={`this.onerror=null;this.src='${PLACEHOLDER}'`} />
          <button class="zoom-btn" id="gallery-zoom" aria-label="Ampliar imagen">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6M8 11h6"/></svg>
          </button>
          {badge && <span class={`detail-badge ${badge.startsWith('-') ? 'sale' : ''}`}>{badge}</span>}
        </div>
        {fotos.length > 1 && (
          <div class="gallery-thumbs">
            {fotos.map((src, i) => (
              <button class={`gallery-thumb ${i === 0 ? 'active' : ''}`} data-src={src} aria-label={`Foto ${i + 1}`}>
                <img src={src} alt="" loading="lazy" onerror={`this.onerror=null;this.style.opacity='.3'`} />
              </button>
            ))}
          </div>
        )}
      </div>

      <div class="detail-info">
        <a class="detail-cat" href={`/productos/?cat=${encodeURIComponent(categoria)}`}>{categoria}</a>
        <h1>{nombre}</h1>
        <div class="detail-rating">
          <span class="stars">{stars}</span>
          <span class="reviews">{rating} · {reviews.toLocaleString('es')} reseñas</span>
        </div>

        <div class="detail-prices">
          <span class="price">{fmt(precio)}</span>
          {precioAnterior && <span class="price-old">{fmt(precioAnterior)}</span>}
          {descuento > 0 && <span class="discount">Ahorras {descuento}%</span>}
        </div>

        <p class="detail-desc">{descripcion}</p>

        <ul class="perks">
          <li><Icon name="truck" size={16} /> Envío express gratis en 24h</li>
          <li><Icon name="shield" size={16} /> Garantía extendida de 2 años</li>
          <li><Icon name="rotate-ccw" size={16} /> Devolución gratuita en 30 días</li>
          <li><Icon name="credit-card" size={16} /> Pago seguro y financiación disponible</li>
        </ul>

        <div class="buy-row">
          <div class="qty-controls">
            <button class="qty-btn" id="detail-dec" aria-label="Menos">−</button>
            <span class="qty-num detail-qty-num" id="detail-qty">1</span>
            <button class="qty-btn" id="detail-inc" aria-label="Más">+</button>
          </div>
          <button class="btn btn-primary buy-btn" data-add={id}><Icon name="cart" size={17} /> Añadir al carrito</button>
        </div>

        <div class="stock"><Icon name="check-circle" size={16} /> En stock — listo para enviar hoy</div>
      </div>
    </section>

    {relacionados.length > 0 && (
      <section class="related">
        <h2 class="section-title">También te puede gustar</h2>
        <div class="related-grid">
          {relacionados.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}
  </main>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" hidden role="dialog" aria-modal="true" aria-label="Vista ampliada">
    <button class="lb-close" id="lb-close" aria-label="Cerrar">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    <button class="lb-arrow lb-prev" id="lb-prev" aria-label="Anterior">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <img id="lb-img" src="" alt="" />
    <button class="lb-arrow lb-next" id="lb-next" aria-label="Siguiente">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    <div class="lb-counter" id="lb-counter"></div>
  </div>

  <Footer />
  <CartDrawer />
</Layout>

<style>
  .main { padding-top: 26px; }

  .breadcrumb { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; font-size: 0.85rem; margin-bottom: 28px; }
  .breadcrumb a { color: var(--text-dim); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }
  .sep { color: var(--text-dim); }
  .current { color: var(--text); font-weight: 600; }

  .detail { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; }

  /* Galería */
  .gallery-wrap { display: flex; gap: 10px; align-items: start; }
  .gallery-main {
    flex: 1; position: relative;
    border-radius: 22px; overflow: hidden;
    box-shadow: var(--shadow-lg); background: var(--bg-soft);
  }
  .gallery-main img {
    width: 100%; aspect-ratio: 1; object-fit: cover;
    transition: opacity 0.18s ease;
  }
  .gallery-main img.switching { opacity: 0; }

  .gallery-thumbs {
    display: flex; flex-direction: column; gap: 8px;
    width: 78px; flex-shrink: 0;
  }
  .gallery-thumb {
    width: 78px; height: 78px;
    border-radius: 12px; overflow: hidden;
    border: 2.5px solid transparent;
    padding: 0; background: var(--bg-soft);
    cursor: pointer; transition: border-color 0.15s, transform 0.15s;
    box-shadow: var(--shadow-sm);
  }
  .gallery-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gallery-thumb.active { border-color: var(--accent); }
  .gallery-thumb:hover:not(.active) { border-color: var(--border); transform: scale(1.04); }

  .detail-badge {
    position: absolute; top: 18px; left: 18px;
    padding: 7px 15px; border-radius: 999px;
    background: var(--text); color: #fff; font-size: 0.82rem; font-weight: 700;
  }
  .detail-badge.sale { background: #dc2626; }

  .detail-cat { font-size: 0.78rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); text-decoration: none; }
  h1 { font-size: clamp(1.7rem, 3.5vw, 2.4rem); font-weight: 800; line-height: 1.12; letter-spacing: -0.02em; margin: 10px 0 12px; }
  .detail-rating { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
  .stars { color: var(--amber); letter-spacing: 2px; }
  .reviews { color: var(--text-dim); font-size: 0.9rem; }

  .detail-prices { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
  .price { font-size: 2.1rem; font-weight: 800; }
  .price-old { font-size: 1.05rem; color: var(--text-dim); text-decoration: line-through; }
  .discount {
    padding: 5px 12px; border-radius: 999px; font-size: 0.8rem; font-weight: 700;
    background: #ecfdf5; color: var(--green); border: 1px solid #a7f3d0;
  }

  .detail-desc { color: var(--text-dim); line-height: 1.7; margin-bottom: 20px; }

  .perks { list-style: none; display: flex; flex-direction: column; gap: 9px; margin-bottom: 26px; }
  .perks li { font-size: 0.92rem; color: var(--text-dim); display: flex; align-items: center; gap: 9px; }
  .perks li :global(svg) { color: var(--accent); flex-shrink: 0; }

  .buy-row {
    display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
    padding: 16px; border-radius: 16px;
    background: var(--bg-soft); border: 1px solid var(--border);
  }
  .qty-controls { display: flex; align-items: center; gap: 12px; }
  .qty-btn {
    width: 38px; height: 38px; border-radius: 11px; border: 1.5px solid var(--border);
    background: #fff; color: var(--text); font-size: 1.05rem; font-weight: 700;
  }
  .qty-btn:hover { border-color: var(--accent); color: var(--accent); }
  .qty-num { min-width: 26px; text-align: center; font-weight: 800; font-size: 1.05rem; }
  .buy-btn { flex: 1; min-width: 190px; }

  .stock { margin-top: 16px; font-size: 0.88rem; font-weight: 700; color: var(--green); display: flex; align-items: center; gap: 8px; }

  .related { margin-top: 90px; }
  .related-grid { display: grid; gap: 22px; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); margin-top: 24px; }

  /* Botón zoom sobre la imagen principal */
  .zoom-btn {
    position: absolute; bottom: 14px; right: 14px; z-index: 2;
    width: 38px; height: 38px; border-radius: 10px;
    background: rgba(255,255,255,0.88); backdrop-filter: blur(6px);
    border: 1px solid var(--border); color: var(--text);
    display: grid; place-items: center; cursor: pointer;
    box-shadow: var(--shadow-sm); transition: all 0.15s;
    opacity: 0; pointer-events: none;
  }
  .gallery-main:hover .zoom-btn { opacity: 1; pointer-events: auto; }
  .gallery-main { cursor: zoom-in; }

  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(8, 10, 20, 0.96); backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    animation: lb-in 0.2s ease;
  }
  .lightbox[hidden] { display: none; }
  @keyframes lb-in { from { opacity: 0; } to { opacity: 1; } }
  #lb-img {
    max-width: min(90vw, 860px); max-height: 82vh;
    object-fit: contain; border-radius: 16px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    animation: lb-scale 0.22s cubic-bezier(0.22,1,0.36,1);
  }
  @keyframes lb-scale { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .lb-close {
    position: fixed; top: 20px; right: 22px;
    width: 44px; height: 44px; border-radius: 12px;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    color: #fff; display: grid; place-items: center; cursor: pointer;
    transition: background 0.15s;
  }
  .lb-close:hover { background: rgba(255,255,255,0.22); }
  .lb-arrow {
    position: fixed; top: 50%; transform: translateY(-50%);
    width: 48px; height: 48px; border-radius: 12px;
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
    color: #fff; display: grid; place-items: center; cursor: pointer;
    transition: background 0.15s;
  }
  .lb-arrow:hover { background: rgba(255,255,255,0.24); }
  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }
  .lb-counter {
    position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,0.6); font-size: 0.85rem; font-weight: 600;
    background: rgba(0,0,0,0.4); padding: 6px 14px; border-radius: 999px;
  }

  @media (max-width: 820px) {
    .detail { grid-template-columns: 1fr; gap: 28px; }
    .gallery-thumbs { flex-direction: row; width: auto; }
    .gallery-thumb { width: 64px; height: 64px; }
    .lb-arrow { display: none; }
  }
</style>

<script>
  // Selector de cantidad
  const qtyEl = document.getElementById('detail-qty');
  document.getElementById('detail-inc').addEventListener('click', () => {
    qtyEl.textContent = Math.min(99, Number(qtyEl.textContent) + 1);
  });
  document.getElementById('detail-dec').addEventListener('click', () => {
    qtyEl.textContent = Math.max(1, Number(qtyEl.textContent) - 1);
  });

  // Galería de fotos
  const mainImg = document.getElementById('gallery-active') as HTMLImageElement | null;
  const thumbs = [...document.querySelectorAll<HTMLButtonElement>('.gallery-thumb')];
  thumbs.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!mainImg || btn.classList.contains('active')) return;
      mainImg.classList.add('switching');
      setTimeout(() => {
        mainImg.src = btn.dataset.src!;
        mainImg.classList.remove('switching');
      }, 160);
      thumbs.forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // Lightbox
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCounter = document.getElementById('lb-counter')!;
  const srcs = thumbs.map(t => t.dataset.src!);
  let lbIndex = 0;

  function openLb(idx: number) {
    lbIndex = idx;
    lbImg.src = srcs[lbIndex];
    lbCounter.textContent = `${lbIndex + 1} / ${srcs.length}`;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function closeLb() {
    lb.hidden = true;
    document.body.style.overflow = '';
  }
  function moveLb(dir: number) {
    lbIndex = (lbIndex + dir + srcs.length) % srcs.length;
    lbImg.style.animation = 'none';
    requestAnimationFrame(() => { lbImg.style.animation = ''; });
    lbImg.src = srcs[lbIndex];
    lbCounter.textContent = `${lbIndex + 1} / ${srcs.length}`;
  }

  // Abrir al clic en imagen principal o botón zoom
  mainImg?.addEventListener('click', () => {
    const activeIdx = thumbs.findIndex(t => t.classList.contains('active'));
    openLb(activeIdx >= 0 ? activeIdx : 0);
  });
  document.getElementById('gallery-zoom')?.addEventListener('click', () => {
    const activeIdx = thumbs.findIndex(t => t.classList.contains('active'));
    openLb(activeIdx >= 0 ? activeIdx : 0);
  });

  document.getElementById('lb-close')?.addEventListener('click', closeLb);
  document.getElementById('lb-prev')?.addEventListener('click', () => moveLb(-1));
  document.getElementById('lb-next')?.addEventListener('click', () => moveLb(1));
  lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', (e) => {
    if (lb.hidden) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') moveLb(-1);
    if (e.key === 'ArrowRight') moveLb(1);
  });
</script>
