---
import Icon from './Icon.astro';
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
const links = [
  { label: 'Inicio', href: base },
  { label: 'Nosotros', href: `${base}nosotros/` },
  { label: 'Productos', href: `${base}productos/` },
  { label: 'Categorías', href: `${base}categorias/` },
  { label: 'Contacto', href: `${base}contacto/` },
];
const norm = (p) => p.replace(/\/$/, '');
const isActive = (href) => (href === base ? norm(path) === norm(base) : path.startsWith(href.replace(/\/$/, '')));
---
<div class="topbar">
  <div class="container topbar-inner">
    <span class="topbar-item"><Icon name="truck" size={15} /> Envío gratis en pedidos superiores a 50 € · Entrega en 24h</span>
    <span class="topbar-right topbar-item"><Icon name="phone" size={14} /> 900 123 456</span>
  </div>
</div>

<header class="header">
  <div class="container header-inner">
    <a href={base} class="logo">
      <span class="logo-icon">N</span>
      <span class="logo-text">Nova<em>Tech</em></span>
    </a>

    <nav class="nav" id="main-nav" aria-label="Navegación principal">
      {links.map((l) => (
        <a href={l.href} class={isActive(l.href) ? 'active' : ''} aria-current={isActive(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <div class="search-wrap">
        <svg class="search-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search-input" type="search" placeholder="Buscar…" autocomplete="off" />
      </div>

      <button id="cart-btn" class="cart-btn" aria-label="Abrir carrito">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        <span id="cart-count" class="cart-count" hidden>0</span>
      </button>

      <button id="menu-btn" class="menu-btn" aria-label="Abrir menú" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
</header>

<script>
  // Búsqueda: si no estamos en /productos (sin #grid), redirige allí con ?q=
  const input = document.getElementById('search-input');
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !document.getElementById('grid') && input.value.trim()) {
      location.href = import.meta.env.BASE_URL + 'productos/?q=' + encodeURIComponent(input.value.trim());
    }
  });

  // Menú móvil
  const menuBtn = document.getElementById('menu-btn');
  const nav = document.getElementById('main-nav');
  menuBtn.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(open));
  });
</script>

<style>
  .topbar { background: var(--text); color: #fff; font-size: 0.8rem; }
  .topbar-inner { display: flex; justify-content: space-between; padding-top: 8px; padding-bottom: 8px; }
  .topbar-item { display: inline-flex; align-items: center; gap: 7px; }
  @media (max-width: 640px) { .topbar-right { display: none; } }

  .header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner { display: flex; align-items: center; gap: 28px; padding-top: 14px; padding-bottom: 14px; }

  .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .logo-icon {
    display: grid; place-items: center; width: 38px; height: 38px;
    background: var(--accent); color: #fff; border-radius: 11px;
    font-weight: 800; font-size: 1.15rem;
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.35);
  }
  .logo-text { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.02em; }
  .logo-text em { font-style: normal; color: var(--accent); }

  .nav { display: flex; gap: 4px; margin: 0 auto; }
  .nav a {
    padding: 9px 16px; border-radius: 10px; text-decoration: none;
    font-size: 0.93rem; font-weight: 600; color: var(--text-dim);
    transition: all 0.15s;
  }
  .nav a:hover { color: var(--text); background: var(--bg-soft); }
  .nav a.active { color: var(--accent); background: var(--accent-soft); }

  .header-actions { display: flex; align-items: center; gap: 12px; }

  .search-wrap { position: relative; }
  .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-dim); }
  .search-wrap input {
    width: 200px; padding: 10px 14px 10px 38px;
    background: var(--bg-soft); border: 1.5px solid transparent;
    border-radius: 11px; font-size: 0.9rem; color: var(--text);
    outline: none; transition: all 0.2s;
  }
  .search-wrap input:focus { background: #fff; border-color: var(--accent); width: 240px; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12); }

  .cart-btn {
    position: relative; display: grid; place-items: center;
    width: 42px; height: 42px; border-radius: 11px;
    background: var(--bg-soft); border: none; color: var(--text);
    transition: background 0.2s;
  }
  .cart-btn:hover { background: var(--accent-soft); color: var(--accent); }
  .cart-count {
    position: absolute; top: -5px; right: -5px;
    min-width: 19px; height: 19px; padding: 0 5px;
    display: grid; place-items: center;
    background: var(--accent); border-radius: 999px;
    font-size: 0.7rem; font-weight: 700; color: #fff;
  }

  .menu-btn { display: none; background: none; border: none; color: var(--text); }

  @media (max-width: 900px) {
    .nav {
      display: none;
      position: absolute; top: 100%; left: 0; right: 0;
      flex-direction: column; gap: 2px; padding: 12px 20px 18px;
      background: #fff; border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-md);
    }
    .nav.open { display: flex; }
    .menu-btn { display: grid; place-items: center; }
    .search-wrap input { width: 150px; }
    .search-wrap input:focus { width: 170px; }
  }
  @media (max-width: 560px) {
    .logo-text { display: none; }
    .header-inner { gap: 12px; }
    .header-actions { margin-left: auto; }
    .search-wrap input { width: 120px; }
    .search-wrap input:focus { width: 140px; }
  }
</style>
