---
import Icon from './Icon.astro';
---
<div id="cart-overlay" class="cart-overlay" hidden></div>

<aside id="cart-drawer" class="cart-drawer" aria-label="Carrito de compras" aria-hidden="true">
  <header class="cart-header">
    <h2>Tu carrito <span id="cart-items-label"></span></h2>
    <button id="cart-close" class="icon-btn" aria-label="Cerrar carrito">✕</button>
  </header>

  <div id="cart-items" class="cart-items"></div>

  <div id="cart-empty" class="cart-empty">
    <span class="empty-icon"><Icon name="cart" size={30} /></span>
    <p>Tu carrito está vacío</p>
    <small>Añade productos para verlos aquí</small>
  </div>

  <footer id="cart-footer" class="cart-footer" hidden>
    <div class="cart-row"><span>Subtotal</span><span id="cart-subtotal">0 €</span></div>
    <div class="cart-row dim"><span>Envío</span><span class="free">Gratis</span></div>
    <div class="cart-row total"><span>Total</span><span id="cart-total">0 €</span></div>
    <button id="checkout-btn" class="checkout-btn">Finalizar compra</button>
    <small class="demo-note">* Demo: el pago no está conectado</small>
  </footer>
</aside>

<div id="toast" class="toast" role="status" aria-live="polite"></div>

<style>
  .cart-overlay {
    position: fixed; inset: 0; z-index: 90;
    background: rgba(16, 24, 40, 0.45); backdrop-filter: blur(2px);
    opacity: 0; transition: opacity 0.25s;
  }
  .cart-overlay.open { opacity: 1; }

  .cart-drawer {
    position: fixed; top: 0; right: 0; z-index: 100;
    width: min(420px, 100vw); height: 100dvh;
    display: flex; flex-direction: column;
    background: #fff; box-shadow: var(--shadow-lg);
    transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cart-drawer.open { transform: translateX(0); }

  .cart-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px; border-bottom: 1px solid var(--border);
  }
  .cart-header h2 { font-size: 1.15rem; font-weight: 800; }
  #cart-items-label { color: var(--text-dim); font-size: 0.9rem; font-weight: 500; }
  .icon-btn {
    width: 34px; height: 34px; border-radius: 9px;
    background: var(--bg-soft); border: none; color: var(--text);
    transition: background 0.2s;
  }
  .icon-btn:hover { background: var(--border); }

  .cart-items { flex: 1; overflow-y: auto; padding: 16px 24px; display: flex; flex-direction: column; gap: 12px; }

  .cart-empty {
    flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
    color: var(--text-dim);
  }
  .empty-icon {
    display: grid; place-items: center; width: 64px; height: 64px;
    border-radius: 18px; background: var(--bg-soft); color: var(--text-dim);
  }
  .cart-empty p { font-weight: 700; color: var(--text); }
  .cart-drawer.has-items .cart-empty { display: none; }

  .cart-footer { padding: 18px 24px 22px; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 8px; }
  .cart-row { display: flex; justify-content: space-between; font-size: 0.93rem; }
  .cart-row.dim { color: var(--text-dim); }
  .free { color: var(--green); font-weight: 700; }
  .cart-row.total { font-size: 1.2rem; font-weight: 800; margin-top: 4px; }
  .checkout-btn {
    margin-top: 8px; padding: 14px; border: none; border-radius: 12px;
    background: var(--accent); color: #fff; font-size: 0.98rem; font-weight: 700;
    box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    transition: all 0.15s;
  }
  .checkout-btn:hover { background: var(--accent-dark); transform: translateY(-1px); }
  .demo-note { text-align: center; color: var(--text-dim); }

  /* Item del carrito (clases usadas desde JS) */
  :global(.cart-item) {
    display: flex; gap: 12px; align-items: center;
    padding: 10px; border-radius: 14px;
    background: var(--bg-soft); border: 1px solid var(--border);
  }
  :global(.cart-item-img) {
    width: 58px; height: 58px; border-radius: 10px; flex-shrink: 0;
    object-fit: cover; background: var(--border);
  }
  :global(.cart-item-info) { flex: 1; min-width: 0; }
  :global(.cart-item-info h4) { font-size: 0.88rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.cart-item-info .item-price) { font-size: 0.82rem; color: var(--text-dim); }
  :global(.qty-controls) { display: flex; align-items: center; gap: 7px; }
  :global(.qty-btn) {
    width: 26px; height: 26px; border-radius: 8px; border: 1px solid var(--border);
    background: #fff; color: var(--text); font-weight: 700;
    display: grid; place-items: center; cursor: pointer;
  }
  :global(.qty-btn:hover) { border-color: var(--accent); color: var(--accent); }
  :global(.qty-num) { min-width: 18px; text-align: center; font-weight: 700; font-size: 0.9rem; }

  .toast {
    position: fixed; bottom: 26px; left: 50%; z-index: 110;
    transform: translate(-50%, 80px);
    padding: 13px 22px; border-radius: 12px;
    background: var(--text); color: #fff;
    font-weight: 600; font-size: 0.92rem;
    box-shadow: var(--shadow-lg);
    opacity: 0; pointer-events: none;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s;
  }
  .toast.show { transform: translate(-50%, 0); opacity: 1; }
</style>

<script>
  // ============================================================
  // CARRITO COMPARTIDO — funciona en todas las páginas.
  // Lee los datos del producto desde data-attributes del
  // elemento más cercano con [data-id] (tarjeta o página detalle).
  // ============================================================
  const fmt = (n) => n.toLocaleString('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
  const drawer = document.getElementById('cart-drawer');
  const overlay = document.getElementById('cart-overlay');
  const itemsEl = document.getElementById('cart-items');
  const countEl = document.getElementById('cart-count');
  const footerEl = document.getElementById('cart-footer');
  const subtotalEl = document.getElementById('cart-subtotal');
  const totalEl = document.getElementById('cart-total');
  const itemsLabel = document.getElementById('cart-items-label');
  const toast = document.getElementById('toast');

  let cart = JSON.parse(localStorage.getItem('novatech-cart') || '{}');
  let toastTimer;

  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
  }

  function openCart() {
    drawer.classList.add('open');
    drawer.setAttribute('aria-hidden', 'false');
    overlay.hidden = false;
    requestAnimationFrame(() => overlay.classList.add('open'));
  }
  function closeCart() {
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('open');
    setTimeout(() => (overlay.hidden = true), 250);
  }

  function renderCart() {
    const entries = Object.values(cart);
    const totalQty = entries.reduce((s, i) => s + i.qty, 0);
    const total = entries.reduce((s, i) => s + i.qty * i.precio, 0);

    countEl.hidden = totalQty === 0;
    countEl.textContent = totalQty;
    drawer.classList.toggle('has-items', totalQty > 0);
    footerEl.hidden = totalQty === 0;
    itemsLabel.textContent = totalQty ? `(${totalQty})` : '';
    subtotalEl.textContent = fmt(total);
    totalEl.textContent = fmt(total);

    itemsEl.innerHTML = entries
      .map(
        (i) => `
      <div class="cart-item">
        <img class="cart-item-img" src="${i.img}" alt="" onerror="this.style.visibility='hidden'">
        <div class="cart-item-info">
          <h4>${i.nombre}</h4>
          <span class="item-price">${fmt(i.precio)}</span>
        </div>
        <div class="qty-controls">
          <button class="qty-btn" data-dec="${i.id}" aria-label="Quitar uno">−</button>
          <span class="qty-num">${i.qty}</span>
          <button class="qty-btn" data-inc="${i.id}" aria-label="Añadir uno">+</button>
        </div>
      </div>`
      )
      .join('');

    localStorage.setItem('novatech-cart', JSON.stringify(cart));
  }

  function addToCart(btn) {
    const src = btn.closest('[data-id]');
    if (!src) return;
    const d = src.dataset;
    const qtyNode = src.querySelector('.detail-qty-num');
    const qty = qtyNode ? Math.max(1, Number(qtyNode.textContent)) : 1;
    if (cart[d.id]) cart[d.id].qty += qty;
    else cart[d.id] = { id: d.id, nombre: d.nombre, precio: Number(d.precio), img: d.img, qty };
    renderCart();
    showToast(`${d.nombre} añadido al carrito ✓`);
  }

  document.addEventListener('click', (e) => {
    const add = e.target.closest('[data-add]');
    const inc = e.target.closest('[data-inc]');
    const dec = e.target.closest('[data-dec]');
    if (add) addToCart(add);
    if (inc) { cart[inc.dataset.inc].qty++; renderCart(); }
    if (dec) {
      const id = dec.dataset.dec;
      cart[id].qty--;
      if (cart[id].qty <= 0) delete cart[id];
      renderCart();
    }
  });

  document.getElementById('cart-btn')?.addEventListener('click', openCart);
  document.getElementById('cart-close').addEventListener('click', closeCart);
  overlay.addEventListener('click', closeCart);
  document.addEventListener('keydown', (e) => e.key === 'Escape' && closeCart());

  document.getElementById('checkout-btn').addEventListener('click', () => {
    showToast('¡Gracias por tu compra! Esto es una demo — aquí iría el checkout.');
    cart = {};
    renderCart();
    closeCart();
  });

  renderCart();
</script>
