---
// Banda de título + breadcrumb para las páginas interiores.
// Props: title, subtitle, crumbs = [{ label, href? }]
const { title, subtitle, crumbs = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<section class="page-header" style={`--ph-bg: url('${base}hero-backgrounds/page-header-bg.webp')`}>
  <div class="container">
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href={base}>Inicio</a>
      {crumbs.map((c) => (
        <>
          <span class="sep">›</span>
          {c.href ? <a href={c.href}>{c.label}</a> : <span class="current">{c.label}</span>}
        </>
      ))}
    </nav>
    <h1>{title}</h1>
    {subtitle && <p>{subtitle}</p>}
  </div>
</section>

<style>
  .page-header {
    background:
      linear-gradient(135deg, rgba(5,10,25,0.55) 0%, rgba(5,10,25,0.45) 100%),
      var(--ph-bg) center/cover no-repeat;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 38px 0 36px;
  }
  .breadcrumb { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; font-size: 0.85rem; margin-bottom: 12px; }
  .breadcrumb a { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.15s; }
  .breadcrumb a:hover { color: #fff; }
  .sep { color: rgba(255,255,255,0.3); }
  .current { color: rgba(255,255,255,0.85); font-weight: 600; }
  h1 { font-size: 32px; font-weight: 800; letter-spacing: -0.02em; color: #fff; }
  p { color: rgba(255,255,255,0.6); margin-top: 8px; max-width: 640px; }
</style>
